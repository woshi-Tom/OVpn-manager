#!/bin/bash
# =====================================================
# VPN Manager - 统一管理脚本
# =====================================================

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 打印带颜色的消息
print_ok() { echo -e "${GREEN}✓ $1${NC}"; }
print_err() { echo -e "${RED}✗ $1${NC}"; }
print_info() { echo -e "${YELLOW}ℹ $1${NC}"; }

# 检查是否以 root 运行
check_root() {
    if [[ $EUID -ne 0 ]]; then
        print_err "此脚本需要 root 权限运行"
        exit 1
    fi
}

case "$1" in
    start)
        check_root
        echo "启动 VPN Manager 服务..."
        
        systemctl start vpn-core
        if [[ $? -eq 0 ]]; then
            print_ok "Core 已启动"
        else
            print_err "Core 启动失败"
        fi
        
        systemctl start vpn-web
        if [[ $? -eq 0 ]]; then
            print_ok "Web 已启动"
        else
            print_err "Web 启动失败"
        fi
        ;;
        
    stop)
        check_root
        echo "停止 VPN Manager 服务..."
        
        systemctl stop vpn-web
        if [[ $? -eq 0 ]]; then
            print_ok "Web 已停止"
        else
            print_err "Web 停止失败"
        fi
        
        systemctl stop vpn-core
        if [[ $? -eq 0 ]]; then
            print_ok "Core 已停止"
        else
            print_err "Core 停止失败"
        fi
        ;;
        
    restart)
        check_root
        $0 stop
        sleep 2
        $0 start
        ;;
        
    status)
        echo "========================================"
        echo "           VPN Manager 状态"
        echo "========================================"
        echo ""
        
        echo "=== Core 状态 ==="
        systemctl status vpn-core --no-pager || true
        echo ""
        
        echo "=== Web 状态 ==="
        systemctl status vpn-web --no-pager || true
        ;;
        
    logs)
        if [[ -f /var/log/vpn-manager/core.log ]]; then
            tail -50 /var/log/vpn-manager/core.log
        else
            print_err "日志文件不存在"
        fi
        ;;
        
    logs-f)
        if [[ -f /var/log/vpn-manager/core.log ]]; then
            tail -f /var/log/vpn-manager/core.log
        else
            print_err "日志文件不存在"
        fi
        ;;
        
    init)
        check_root
        print_info "初始化数据库..."
        
        if [[ -f /etc/vpn-manager/schema.sql ]]; then
            psql -U vpn_core -d vpn_db -f /etc/vpn-manager/schema.sql
            if [[ $? -eq 0 ]]; then
                print_ok "数据库初始化完成"
            else
                print_err "数据库初始化失败"
            fi
        else
            print_err "schema.sql 文件不存在"
        fi
        ;;
        
    enable)
        check_root
        systemctl enable vpn-core vpn-web
        print_ok "已设为开机自启"
        ;;
        
    disable)
        check_root
        systemctl disable vpn-core vpn-web
        print_ok "已取消开机自启"
        ;;
        
    *)
        echo "用法: $0 {start|stop|restart|status|logs|logs-f|init|enable|disable}"
        echo ""
        echo "命令说明:"
        echo "  start     - 启动所有服务"
        echo "  stop      - 停止所有服务"
        echo "  restart   - 重启所有服务"
        echo "  status    - 查看服务状态"
        echo "  logs      - 查看最近50条日志"
        echo "  logs-f    - 实时查看日志 (Ctrl+C 退出)"
        echo "  init      - 初始化数据库"
        echo "  enable    - 设为开机自启"
        echo "  disable   - 取消开机自启"
        exit 1
        ;;
esac
